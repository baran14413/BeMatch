rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Kullanıcıların kendi profil fotoğraflarını yönetmesine izin ver
    // Herkes profil fotoğraflarını okuyabilir (genel okuma)
    match /users/{userId}/photos/{photoId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Sohbet içindeki resimlere erişim
    // Sadece eşleşmenin parçası olan kullanıcılar okuyabilir ve yazabilir
    match /chats/{matchId}/images/{imageId} {
       allow read, write: if request.auth != null && exists(/databases/$(database)/documents/matches/$(matchId)) && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users;
    }

    // Sohbet içindeki sesli mesajlara erişim
    match /chats/{matchId}/voice_messages/{audioId} {
       allow read, write: if request.auth != null && exists(/databases/$(database)/documents/matches/$(matchId)) && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users;
    }

    // Kullanıcıların kendi şikayetleri için ekran görüntüsü yüklemesine izin ver
    match /reports/{userId}/{screenshotId} {
      allow write: if request.auth != null && request.auth.uid == userId;
      // Not: Raporları okuma yetkisi sadece admin/moderator'lere özel olmalı, bu yüzden client'tan okuma izni yok.
      allow read: if false; 
    }
  }
}
