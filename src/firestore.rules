
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Any authenticated user can read public user profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      // Admins can write to any user's profile.
      // Users can only write to their own profile.
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.token.role == 'admin');
    }
    
    // Users can read/write their own subcollections (e.g. for future features)
    match /users/{userId}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Users can write to another user's 'likedBy' subcollection
    match /users/{targetUserId}/likedBy/{likerId} {
      allow read: if request.auth != null && (request.auth.uid == targetUserId || request.auth.uid == likerId);
      allow write: if request.auth != null && request.auth.uid == likerId;
    }
    
    // A user can read/write a match document if they are a participant
    // An admin can get any single match document
    match /matches/{matchId} {
      allow get: if request.auth != null && (request.auth.uid in resource.data.users || request.auth.token.role == 'admin');
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.users;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.users;

      // Messages can be read/written by participants of the parent match or by an admin
      match /messages/{messageId} {
        allow read, write: if request.auth != null && (get(/databases/$(database)/documents/matches/$(matchId)).data.users.hasAny([request.auth.uid]) || request.auth.token.role == 'admin');
      }
    }

    // Reports can be created by any authenticated user
    match /reports/{reportId} {
      allow create: if request.auth != null && request.resource.data.reporterId == request.auth.uid;
      // Admins and moderators can read/update reports
      allow read, update: if request.auth != null && request.auth.token.role in ['admin', 'moderator'];
    }

    // A user can write their own deletion record. No one can read it from the client.
    match /deletedUsers/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if false; // No client read access
    }
  }
}
