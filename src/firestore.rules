rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. PATRON TANIMI ---
    // Buraya senin UID'ni ve varsa 'admin' rolünü ekliyoruz.
    function isSuperAdmin() {
       return request.auth.uid == "cWlIeCIWvqgP57o9pjDjHuIXoJ92" || request.auth.token.role == 'admin';
    }

    // --- 2. MASTER KEY (HAYAT KURTARAN KISIM) 🔑 ---
    // Eğer giren kişi SENSEN (isSuperAdmin), veritabanındaki HER ŞEYİ okur, yazar, siler, listeler.
    // Bu kural diğer tüm kuralların üzerine yazar.
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --- 3. NORMAL KULLANICI KURALLARI (Senin Orijinal Kodların) ---
    // (Admin zaten yukarıdan yetki aldı, burası sadece normal üyeler için)

    match /users/{userId} {
      allow read: if request.auth != null;
      // Normal kullanıcı sadece kendi profilini düzenler
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /users/{targetUserId}/likedBy/{likerId} {
      allow read: if request.auth != null && (request.auth.uid == targetUserId || request.auth.uid == likerId);
      allow write: if request.auth != null && request.auth.uid == likerId;
    }
    
    // MAÇLAR (Burayı düzelttik)
    match /matches/{matchId} {
      // 'allow get' yerine 'allow read' yaptık. 
      // Admin yukarıdan yetkili olduğu için buradaki kural sadece katılımcıları ilgilendirir.
      allow read: if request.auth != null && request.auth.uid in resource.data.users;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.users;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.users;

      match /messages/{messageId} {
        // Burada da admin kontrolüne gerek kalmadı, yukarıdaki Master Key hallediyor.
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/matches/$(matchId)).data.users.hasAny([request.auth.uid]);
      }
    }

    match /reports/{reportId} {
      allow create: if request.auth != null && request.resource.data.reporterId == request.auth.uid;
      // Okuma yetkisi admin için yukarıda verildi.
      allow read, update: if false; // Normal kullanıcılar raporları okuyamaz.
    }

    match /deletedUsers/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if false; 
    }
  }
}