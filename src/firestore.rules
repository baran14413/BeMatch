rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. PATRON TANIMI (Senin UID) ---
    function isSuperAdmin() {
       return request.auth.uid == "cWlIeCIWvqgP57o9pjDjHuIXoJ92";
    }

    // --- 2. KULLANICILAR ---
    match /users/{userId} {
      allow read: if request.auth != null;
      // Admin her şeyi yazar, kullanıcı sadece kendini yazar
      allow write: if isSuperAdmin() || (request.auth != null && request.auth.uid == userId);
    }
    
    // Alt koleksiyonlar
    match /users/{userId}/{document=**} {
      allow read, write: if isSuperAdmin() || (request.auth != null && request.auth.uid == userId);
    }
    
    match /users/{targetUserId}/likedBy/{likerId} {
      allow read: if isSuperAdmin() || (request.auth != null && (request.auth.uid == targetUserId || request.auth.uid == likerId));
      allow write: if isSuperAdmin() || (request.auth != null && request.auth.uid == likerId);
    }
    
    // --- 3. MAÇLAR (HATAYI ÇÖZEN KISIM 🚨) ---
    // Buraya '|| isSuperAdmin()' şartını elle ekledik. Artık kaçarı yok.
    match /matches/{matchId} {
      
      // OKUMA: Ya içindeki kullanıcısındır YA DA Patronsundur.
      allow read: if isSuperAdmin() || (request.auth != null && request.auth.uid in resource.data.users);
      
      // GÜNCELLEME/SİLME: Yine Patron veya Kullanıcı.
      allow update, delete: if isSuperAdmin() || (request.auth != null && request.auth.uid in resource.data.users);
      
      // OLUŞTURMA: Admin veya Kullanıcı.
      allow create: if isSuperAdmin() || (request.auth != null && request.auth.uid in request.resource.data.users);

      // Mesajlar (Alt Koleksiyon)
      match /messages/{messageId} {
        allow read, write: if isSuperAdmin() || (
          request.auth != null && 
          get(/databases/$(database)/documents/matches/$(matchId)).data.users.hasAny([request.auth.uid])
        );
      }
    }

    // --- 4. DİĞERLERİ ---
    match /reports/{reportId} {
      // Raporu herkes oluşturabilir, ama sadece Admin okuyabilir/düzenleyebilir.
      allow create: if request.auth != null && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if isSuperAdmin();
    }

    match /deletedUsers/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if isSuperAdmin(); 
    }
    
    // Geri kalan her yer için genel kilit (Sadece sen açabilirsin)
    match /{document=**} {
       allow read, write: if isSuperAdmin();
    }
  }
}